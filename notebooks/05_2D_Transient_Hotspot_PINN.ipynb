import torch
import torch.nn as nn
import numpy as np
import matplotlib.pyplot as plt

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print("Using device:", device)

# ------------------------------------------------------------
# Constants
# ------------------------------------------------------------

T0 = 300.0
alpha = 0.1

Q0 = 5.0
x_c, y_c = 0.5, 0.5
sigma = 0.10


# ------------------------------------------------------------
# Heat Source
# ------------------------------------------------------------

def source_torch(x, y):
    return Q0 * torch.exp(
        -((x - x_c) ** 2 + (y - y_c) ** 2) / (2 * sigma ** 2)
    )


def source_numpy(X, Y):
    return Q0 * np.exp(
        -((X - x_c) ** 2 + (Y - y_c) ** 2) / (2 * sigma ** 2)
    )


# ------------------------------------------------------------
# PINN Model
# ------------------------------------------------------------

class TransientHeat2DPINN(nn.Module):
    def __init__(self, hidden_dim=80, num_hidden_layers=6):
        super().__init__()

        layers = [nn.Linear(3, hidden_dim), nn.Tanh()]

        for _ in range(num_hidden_layers):
            layers += [nn.Linear(hidden_dim, hidden_dim), nn.Tanh()]

        layers.append(nn.Linear(hidden_dim, 1))

        self.network = nn.Sequential(*layers)

    def forward(self, x, y, t):
        inputs = torch.cat([x, y, t], dim=1)

        raw = self.network(inputs)

        boundary_factor = x * (1 - x) * y * (1 - y)
        time_factor = 1 - torch.exp(-t)

        return T0 + time_factor * boundary_factor * raw


# ------------------------------------------------------------
# PDE Loss
# ------------------------------------------------------------

def pde_loss(model, x, y, t):
    x.requires_grad_(True)
    y.requires_grad_(True)
    t.requires_grad_(True)

    T = model(x, y, t)

    T_t = torch.autograd.grad(
        T, t,
        grad_outputs=torch.ones_like(T),
        create_graph=True
    )[0]

    T_x = torch.autograd.grad(
        T, x,
        grad_outputs=torch.ones_like(T),
        create_graph=True
    )[0]

    T_y = torch.autograd.grad(
        T, y,
        grad_outputs=torch.ones_like(T),
        create_graph=True
    )[0]

    T_xx = torch.autograd.grad(
        T_x, x,
        grad_outputs=torch.ones_like(T_x),
        create_graph=True
    )[0]

    T_yy = torch.autograd.grad(
        T_y, y,
        grad_outputs=torch.ones_like(T_y),
        create_graph=True
    )[0]

    S = source_torch(x, y)

    residual = T_t - alpha * (T_xx + T_yy) - S

    return torch.mean(residual ** 2)


# ------------------------------------------------------------
# IC / BC Monitor
# ------------------------------------------------------------

def constraint_error(model, n=80):
    vals = torch.linspace(0, 1, n).view(-1, 1).to(device)

    zeros = torch.zeros_like(vals)
    ones = torch.ones_like(vals)

    with torch.no_grad():
        t_vals = vals

        T_left = model(zeros, vals, t_vals)
        T_right = model(ones, vals, t_vals)
        T_bottom = model(vals, zeros, t_vals)
        T_top = model(vals, ones, t_vals)

        T_init = model(vals, vals, zeros)

    bc_error = (
        torch.mean(torch.abs(T_left - T0))
        + torch.mean(torch.abs(T_right - T0))
        + torch.mean(torch.abs(T_bottom - T0))
        + torch.mean(torch.abs(T_top - T0))
    ) / 4

    ic_error = torch.mean(torch.abs(T_init - T0))

    return bc_error.item(), ic_error.item()


# ------------------------------------------------------------
# Stable Explicit FDM Solver
# ------------------------------------------------------------

def transient_fdm(nx=80, ny=80, t_final=1.0, safety=0.8):
    x = np.linspace(0, 1, nx)
    y = np.linspace(0, 1, ny)

    dx = x[1] - x[0]
    dy = y[1] - y[0]

    stability_limit = 1.0 / (
        2.0 * alpha * (1.0 / dx**2 + 1.0 / dy**2)
    )

    dt = safety * stability_limit
    nt = int(np.ceil(t_final / dt))
    dt = t_final / nt

    print("Stable FDM settings:")
    print(f"dx = {dx:.4e}, dy = {dy:.4e}")
    print(f"dt = {dt:.4e}, nt = {nt}")
    print(f"stability limit = {stability_limit:.4e}")

    X, Y = np.meshgrid(x, y)

    S = source_numpy(X, Y)

    T = np.ones((ny, nx)) * T0

    snapshot_times = [0.0, 0.25, 0.5, 0.75, 1.0]
    snapshots = {0.0: T.copy()}

    center_history_t = [0.0]
    center_history_T = [T[ny // 2, nx // 2]]

    for n_step in range(1, nt + 1):
        T_new = T.copy()

        T_new[1:-1, 1:-1] = (
            T[1:-1, 1:-1]
            + alpha * dt * (
                (T[1:-1, 2:] - 2.0 * T[1:-1, 1:-1] + T[1:-1, :-2]) / dx**2
                + (T[2:, 1:-1] - 2.0 * T[1:-1, 1:-1] + T[:-2, 1:-1]) / dy**2
            )
            + dt * S[1:-1, 1:-1]
        )

        T_new[0, :] = T0
        T_new[-1, :] = T0
        T_new[:, 0] = T0
        T_new[:, -1] = T0

        if np.isnan(T_new).any() or np.isinf(T_new).any():
            raise RuntimeError("FDM became unstable: NaN or Inf detected.")

        T = T_new
        current_time = n_step * dt

        center_history_t.append(current_time)
        center_history_T.append(T[ny // 2, nx // 2])

        for st in snapshot_times:
            if st not in snapshots and current_time >= st:
                snapshots[st] = T.copy()

    snapshots[1.0] = T.copy()

    return (
        X,
        Y,
        snapshots,
        np.array(center_history_t),
        np.array(center_history_T)
    )


# ------------------------------------------------------------
# Training
# ------------------------------------------------------------

model = TransientHeat2DPINN().to(device)

optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)

epochs = 20000
n_collocation = 5000

loss_history = []

for epoch in range(epochs):
    x_pde = torch.rand((n_collocation, 1), device=device)
    y_pde = torch.rand((n_collocation, 1), device=device)
    t_pde = torch.rand((n_collocation, 1), device=device)

    loss = pde_loss(model, x_pde, y_pde, t_pde)

    optimizer.zero_grad()
    loss.backward()
    optimizer.step()

    loss_history.append(loss.item())

    if epoch % 1000 == 0:
        bc_err, ic_err = constraint_error(model)

        print(
            f"Epoch {epoch:05d} | "
            f"PDE Loss: {loss.item():.8e} | "
            f"BC Error: {bc_err:.3e} | "
            f"IC Error: {ic_err:.3e}"
        )


# ------------------------------------------------------------
# FDM Benchmark
# ------------------------------------------------------------

X, Y, fdm_snapshots, fdm_time, fdm_center = transient_fdm(
    nx=80,
    ny=80,
    t_final=1.0,
    safety=0.8
)


# ------------------------------------------------------------
# PINN Evaluation Function
# ------------------------------------------------------------

def evaluate_pinn_at_time(model, X, Y, time_value):
    x_flat = torch.tensor(
        X.reshape(-1, 1),
        dtype=torch.float32,
        device=device
    )

    y_flat = torch.tensor(
        Y.reshape(-1, 1),
        dtype=torch.float32,
        device=device
    )

    t_flat = torch.ones_like(x_flat) * time_value

    with torch.no_grad():
        T_flat = model(x_flat, y_flat, t_flat).cpu().numpy()

    return T_flat.reshape(X.shape)


# ------------------------------------------------------------
# Snapshot Comparison
# ------------------------------------------------------------

snapshot_times = [0.0, 0.25, 0.5, 0.75, 1.0]

for time_value in snapshot_times:
    T_pinn = evaluate_pinn_at_time(model, X, Y, time_value)
    T_fdm = fdm_snapshots[time_value]

    error = T_pinn - T_fdm

    mae = np.mean(np.abs(error))
    rmse = np.sqrt(np.mean(error ** 2))
    max_error = np.max(np.abs(error))
    rel_l2 = np.linalg.norm(error) / np.linalg.norm(T_fdm)

    print(f"\nTime t = {time_value}")
    print("MAE        :", mae)
    print("RMSE       :", rmse)
    print("Max Error  :", max_error)
    print("Relative L2:", rel_l2)
    print("PINN Tmax  :", np.max(T_pinn))
    print("FDM Tmax   :", np.max(T_fdm))

    plt.figure(figsize=(7, 5))
    contour = plt.contourf(X, Y, T_pinn, levels=50)
    plt.colorbar(contour, label="Temperature (K)")
    plt.xlabel("x")
    plt.ylabel("y")
    plt.title(f"PINN Temperature Field at t={time_value}")
    plt.tight_layout()
    plt.show()

    plt.figure(figsize=(7, 5))
    contour = plt.contourf(X, Y, T_fdm, levels=50)
    plt.colorbar(contour, label="Temperature (K)")
    plt.xlabel("x")
    plt.ylabel("y")
    plt.title(f"FDM Temperature Field at t={time_value}")
    plt.tight_layout()
    plt.show()

    plt.figure(figsize=(7, 5))
    contour = plt.contourf(X, Y, error, levels=50)
    plt.colorbar(contour, label="PINN - FDM Error (K)")
    plt.xlabel("x")
    plt.ylabel("y")
    plt.title(f"Error Heatmap at t={time_value}")
    plt.tight_layout()
    plt.show()


# ------------------------------------------------------------
# Training Loss
# ------------------------------------------------------------

plt.figure(figsize=(7, 5))
plt.semilogy(loss_history, linewidth=2)
plt.xlabel("Epoch")
plt.ylabel("PDE Loss")
plt.title("PINN Training Loss: 2D Transient Heat Equation")
plt.grid(True)
plt.tight_layout()
plt.show()


# ------------------------------------------------------------
# Center Hotspot Temperature Evolution
# ------------------------------------------------------------

time_values = np.linspace(0, 1, 150)

x_center = torch.ones((len(time_values), 1), device=device) * 0.5
y_center = torch.ones((len(time_values), 1), device=device) * 0.5

t_center = torch.tensor(
    time_values.reshape(-1, 1),
    dtype=torch.float32,
    device=device
)

with torch.no_grad():
    center_pinn = model(
        x_center,
        y_center,
        t_center
    ).cpu().numpy().flatten()

plt.figure(figsize=(7, 5))

plt.plot(
    time_values,
    center_pinn,
    label="PINN Center Temperature",
    linewidth=2
)

plt.plot(
    fdm_time,
    fdm_center,
    "--",
    label="FDM Center Temperature",
    linewidth=2
)

plt.xlabel("t")
plt.ylabel("T(0.5, 0.5, t) [K]")
plt.title("Center Hotspot Temperature Evolution")
plt.legend()
plt.grid(True)
plt.tight_layout()
plt.show()
