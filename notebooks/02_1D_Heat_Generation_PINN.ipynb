import torch
import torch.nn as nn
import numpy as np
import matplotlib.pyplot as plt

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print("Using device:", device)

# --------------------------------------------------
# Physical Parameters
# --------------------------------------------------

T_left = 400.0
T_right = 300.0

k = 10.0
Q = 1000.0

source_strength = Q / k


# --------------------------------------------------
# Analytical Solution
# --------------------------------------------------

def analytical_solution(x):
    return (
        T_left * (1 - x)
        + T_right * x
        + (Q / (2 * k)) * x * (1 - x)
    )


# --------------------------------------------------
# PINN Model
# --------------------------------------------------

class PINN(nn.Module):
    def __init__(self, hidden_dim=64, num_hidden_layers=4):
        super().__init__()

        layers = [nn.Linear(1, hidden_dim), nn.Tanh()]

        for _ in range(num_hidden_layers):
            layers += [nn.Linear(hidden_dim, hidden_dim), nn.Tanh()]

        layers.append(nn.Linear(hidden_dim, 1))

        self.network = nn.Sequential(*layers)

    def forward(self, x):

        raw_output = self.network(x)

        boundary_solution = (
            T_left * (1 - x)
            + T_right * x
        )

        correction = x * (1 - x) * raw_output

        return boundary_solution + correction


# --------------------------------------------------
# PDE Loss
# --------------------------------------------------

def pde_loss(model, x):

    x.requires_grad_(True)

    T = model(x)

    dT_dx = torch.autograd.grad(
        T,
        x,
        grad_outputs=torch.ones_like(T),
        create_graph=True
    )[0]

    d2T_dx2 = torch.autograd.grad(
        dT_dx,
        x,
        grad_outputs=torch.ones_like(dT_dx),
        create_graph=True
    )[0]

    residual = d2T_dx2 + source_strength

    return torch.mean(residual ** 2)


# --------------------------------------------------
# Training
# --------------------------------------------------

model = PINN().to(device)

optimizer = torch.optim.Adam(
    model.parameters(),
    lr=1e-3
)

epochs = 12000
n_collocation = 200

loss_history = []

for epoch in range(epochs):

    x_pde = torch.rand(
        (n_collocation, 1),
        device=device
    )

    loss = pde_loss(model, x_pde)

    optimizer.zero_grad()
    loss.backward()
    optimizer.step()

    loss_history.append(loss.item())

    if epoch % 1000 == 0:

        print(
            f"Epoch {epoch:05d} | "
            f"PDE Loss: {loss.item():.8e}"
        )


# --------------------------------------------------
# Evaluation
# --------------------------------------------------

x_test = torch.linspace(
    0, 1, 300
).view(-1, 1).to(device)

with torch.no_grad():
    T_pinn = model(x_test).cpu().numpy()

x_np = x_test.cpu().numpy()

T_exact = analytical_solution(x_np)

error = T_pinn - T_exact

mae = np.mean(np.abs(error))
rmse = np.sqrt(np.mean(error ** 2))

print("\nFinal Evaluation:")
print("MAE :", mae)
print("RMSE:", rmse)


# --------------------------------------------------
# PINN vs Exact
# --------------------------------------------------

plt.figure(figsize=(7,5))

plt.plot(
    x_np,
    T_exact,
    label="Analytical Solution",
    linewidth=2
)

plt.plot(
    x_np,
    T_pinn,
    "--",
    label="PINN Prediction",
    linewidth=2
)

plt.xlabel("x")
plt.ylabel("Temperature (K)")
plt.title("1D Heat Conduction with Internal Heat Generation")
plt.legend()
plt.grid(True)
plt.show()


# --------------------------------------------------
# Error Plot
# --------------------------------------------------

plt.figure(figsize=(7,5))

plt.plot(
    x_np,
    error,
    linewidth=2
)

plt.xlabel("x")
plt.ylabel("Error (K)")
plt.title("PINN Prediction Error")
plt.grid(True)
plt.show()


# --------------------------------------------------
# Loss Curve
# --------------------------------------------------

plt.figure(figsize=(7,5))

plt.semilogy(loss_history)

plt.xlabel("Epoch")
plt.ylabel("PDE Loss")
plt.title("Training Loss")
plt.grid(True)
plt.show()


# --------------------------------------------------
# Sample Values
# --------------------------------------------------

sample_points = torch.tensor(
    [[0.0],
     [0.25],
     [0.50],
     [0.75],
     [1.0]],
    device=device
)

with torch.no_grad():
    sample_pred = model(sample_points).cpu().numpy()

sample_exact = analytical_solution(
    sample_points.cpu().numpy()
)

print("\nSample Temperature Comparison:")
print("x     PINN       Exact")

for x_val, pred, exact in zip(
    sample_points.cpu().numpy(),
    sample_pred,
    sample_exact
):
    print(
        f"{x_val[0]:.2f}  "
        f"{pred[0]:.6f}  "
        f"{exact[0]:.6f}"
    )
