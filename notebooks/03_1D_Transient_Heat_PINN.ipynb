import torch
import torch.nn as nn
import numpy as np
import matplotlib.pyplot as plt

# ------------------------------------------------------------
# Device
# ------------------------------------------------------------

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print("Using device:", device)

# ------------------------------------------------------------
# Parameters
# ------------------------------------------------------------

alpha = 0.1
pi = np.pi

# ------------------------------------------------------------
# Analytical Solution
# ------------------------------------------------------------

def analytical_solution(x, t):
    return np.exp(-alpha * pi**2 * t) * np.sin(pi * x)

# ------------------------------------------------------------
# PINN Model
# ------------------------------------------------------------

class TransientHeatPINN(nn.Module):
    def __init__(self, hidden_dim=64, num_hidden_layers=5):
        super().__init__()

        layers = [nn.Linear(2, hidden_dim), nn.Tanh()]

        for _ in range(num_hidden_layers):
            layers += [
                nn.Linear(hidden_dim, hidden_dim),
                nn.Tanh()
            ]

        layers.append(nn.Linear(hidden_dim, 1))

        self.network = nn.Sequential(*layers)

    def forward(self, x, t):

        inputs = torch.cat([x, t], dim=1)

        raw = self.network(inputs)

        # Hard BC:
        # u(0,t)=0
        # u(1,t)=0

        u = x * (1 - x) * raw

        return u

# ------------------------------------------------------------
# PDE Loss
# ------------------------------------------------------------

def pde_loss(model, x, t):

    x.requires_grad_(True)
    t.requires_grad_(True)

    u = model(x, t)

    u_t = torch.autograd.grad(
        u,
        t,
        grad_outputs=torch.ones_like(u),
        create_graph=True
    )[0]

    u_x = torch.autograd.grad(
        u,
        x,
        grad_outputs=torch.ones_like(u),
        create_graph=True
    )[0]

    u_xx = torch.autograd.grad(
        u_x,
        x,
        grad_outputs=torch.ones_like(u_x),
        create_graph=True
    )[0]

    residual = u_t - alpha * u_xx

    return torch.mean(residual ** 2)

# ------------------------------------------------------------
# Initial Condition Loss
# ------------------------------------------------------------

def initial_condition_loss(model, x_ic):

    t_ic = torch.zeros_like(x_ic)

    u_pred = model(x_ic, t_ic)

    u_true = torch.sin(torch.pi * x_ic)

    return torch.mean((u_pred - u_true) ** 2)

# ------------------------------------------------------------
# Training
# ------------------------------------------------------------

model = TransientHeatPINN().to(device)

optimizer = torch.optim.Adam(
    model.parameters(),
    lr=1e-3
)

epochs = 15000

n_pde = 500
n_ic = 200

lambda_ic = 10.0

loss_history = []
pde_history = []
ic_history = []

for epoch in range(epochs):

    x_pde = torch.rand((n_pde, 1), device=device)
    t_pde = torch.rand((n_pde, 1), device=device)

    x_ic = torch.rand((n_ic, 1), device=device)

    loss_pde = pde_loss(
        model,
        x_pde,
        t_pde
    )

    loss_ic = initial_condition_loss(
        model,
        x_ic
    )

    total_loss = (
        loss_pde
        + lambda_ic * loss_ic
    )

    optimizer.zero_grad()
    total_loss.backward()
    optimizer.step()

    loss_history.append(total_loss.item())
    pde_history.append(loss_pde.item())
    ic_history.append(loss_ic.item())

    if epoch % 1000 == 0:

        print(
            f"Epoch {epoch:05d} | "
            f"Total Loss: {total_loss.item():.8e} | "
            f"PDE Loss: {loss_pde.item():.8e} | "
            f"IC Loss: {loss_ic.item():.8e}"
        )

# ------------------------------------------------------------
# Evaluation Grid
# ------------------------------------------------------------

nx = 150
nt = 150

x = np.linspace(0, 1, nx)
t = np.linspace(0, 1, nt)

X, T_grid = np.meshgrid(x, t)

x_flat = torch.tensor(
    X.reshape(-1, 1),
    dtype=torch.float32,
    device=device
)

t_flat = torch.tensor(
    T_grid.reshape(-1, 1),
    dtype=torch.float32,
    device=device
)

with torch.no_grad():

    u_pinn_flat = model(
        x_flat,
        t_flat
    ).cpu().numpy()

U_pinn = u_pinn_flat.reshape(nt, nx)

U_exact = analytical_solution(
    X,
    T_grid
)

error = U_pinn - U_exact

# ------------------------------------------------------------
# Metrics
# ------------------------------------------------------------

mae = np.mean(np.abs(error))
rmse = np.sqrt(np.mean(error ** 2))
max_error = np.max(np.abs(error))

print("\nFinal Evaluation:")
print("MAE       :", mae)
print("RMSE      :", rmse)
print("Max Error :", max_error)

# ------------------------------------------------------------
# PINN Solution
# ------------------------------------------------------------

plt.figure(figsize=(8,5))

contour = plt.contourf(
    X,
    T_grid,
    U_pinn,
    levels=50
)

plt.colorbar(contour)

plt.xlabel("x")
plt.ylabel("t")
plt.title("PINN Solution")
plt.show()

# ------------------------------------------------------------
# Analytical Solution
# ------------------------------------------------------------

plt.figure(figsize=(8,5))

contour = plt.contourf(
    X,
    T_grid,
    U_exact,
    levels=50
)

plt.colorbar(contour)

plt.xlabel("x")
plt.ylabel("t")
plt.title("Analytical Solution")
plt.show()

# ------------------------------------------------------------
# Error Heatmap
# ------------------------------------------------------------

plt.figure(figsize=(8,5))

contour = plt.contourf(
    X,
    T_grid,
    error,
    levels=50
)

plt.colorbar(contour)

plt.xlabel("x")
plt.ylabel("t")
plt.title("Error Heatmap")
plt.show()

# ------------------------------------------------------------
# Time Snapshots
# ------------------------------------------------------------

snapshot_times = [0.0, 0.25, 0.5, 0.75, 1.0]

plt.figure(figsize=(8,5))

for tv in snapshot_times:

    idx = np.argmin(np.abs(t - tv))

    plt.plot(
        x,
        U_exact[idx],
        linewidth=2,
        label=f"Exact t={tv}"
    )

    plt.plot(
        x,
        U_pinn[idx],
        "--",
        linewidth=2,
        label=f"PINN t={tv}"
    )

plt.xlabel("x")
plt.ylabel("u(x,t)")
plt.title("Transient Heat Diffusion")
plt.legend()
plt.grid(True)
plt.show()

# ------------------------------------------------------------
# Training Loss
# ------------------------------------------------------------

plt.figure(figsize=(8,5))

plt.semilogy(loss_history, label="Total")
plt.semilogy(pde_history, label="PDE")
plt.semilogy(ic_history, label="IC")

plt.xlabel("Epoch")
plt.ylabel("Loss")
plt.title("Training Loss")
plt.legend()
plt.grid(True)
plt.show()

# ------------------------------------------------------------
# Center Temperature Decay
# ------------------------------------------------------------

x_center = np.ones_like(t) * 0.5

u_exact_center = analytical_solution(
    x_center,
    t
)

x_center_tensor = torch.tensor(
    x_center.reshape(-1,1),
    dtype=torch.float32,
    device=device
)

t_tensor = torch.tensor(
    t.reshape(-1,1),
    dtype=torch.float32,
    device=device
)

with torch.no_grad():

    u_pinn_center = model(
        x_center_tensor,
        t_tensor
    ).cpu().numpy().flatten()

plt.figure(figsize=(8,5))

plt.plot(
    t,
    u_exact_center,
    linewidth=2,
    label="Exact"
)

plt.plot(
    t,
    u_pinn_center,
    "--",
    linewidth=2,
    label="PINN"
)

plt.xlabel("t")
plt.ylabel("u(0.5,t)")
plt.title("Center Temperature Decay")
plt.legend()
plt.grid(True)
plt.show()
