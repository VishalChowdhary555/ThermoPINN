import torch
import torch.nn as nn
import numpy as np
import matplotlib.pyplot as plt

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print("Using device:", device)

T_boundary = 300.0

k = 10.0
Q0 = 500.0

x_c = 0.5
y_c = 0.5
sigma = 0.10


def heat_source_torch(x, y):
    return Q0 * torch.exp(
        -((x - x_c) ** 2 + (y - y_c) ** 2) / (2 * sigma ** 2)
    )


def heat_source_numpy(X, Y):
    return Q0 * np.exp(
        -((X - x_c) ** 2 + (Y - y_c) ** 2) / (2 * sigma ** 2)
    )


class Heat2DPINN(nn.Module):
    def __init__(self, hidden_dim=80, num_hidden_layers=6):
        super().__init__()

        layers = [nn.Linear(2, hidden_dim), nn.Tanh()]

        for _ in range(num_hidden_layers):
            layers += [nn.Linear(hidden_dim, hidden_dim), nn.Tanh()]

        layers.append(nn.Linear(hidden_dim, 1))

        self.network = nn.Sequential(*layers)

    def forward(self, x, y):
        inputs = torch.cat([x, y], dim=1)

        raw = self.network(inputs)

        boundary_factor = x * (1 - x) * y * (1 - y)

        return T_boundary + boundary_factor * raw


def pde_loss(model, x, y):
    x.requires_grad_(True)
    y.requires_grad_(True)

    T = model(x, y)

    T_x = torch.autograd.grad(
        T, x,
        grad_outputs=torch.ones_like(T),
        create_graph=True
    )[0]

    T_y = torch.autograd.grad(
        T, y,
        grad_outputs=torch.ones_like(T),
        create_graph=True
    )[0]

    T_xx = torch.autograd.grad(
        T_x, x,
        grad_outputs=torch.ones_like(T_x),
        create_graph=True
    )[0]

    T_yy = torch.autograd.grad(
        T_y, y,
        grad_outputs=torch.ones_like(T_y),
        create_graph=True
    )[0]

    Q = heat_source_torch(x, y)

    residual = T_xx + T_yy + Q / k

    return torch.mean(residual ** 2)


def boundary_error(model, n=100):
    vals = torch.linspace(0, 1, n).view(-1, 1).to(device)

    zeros = torch.zeros_like(vals)
    ones = torch.ones_like(vals)

    with torch.no_grad():
        T_left = model(zeros, vals)
        T_right = model(ones, vals)
        T_bottom = model(vals, zeros)
        T_top = model(vals, ones)

    err = (
        torch.mean(torch.abs(T_left - T_boundary))
        + torch.mean(torch.abs(T_right - T_boundary))
        + torch.mean(torch.abs(T_bottom - T_boundary))
        + torch.mean(torch.abs(T_top - T_boundary))
    ) / 4

    return err.item()


def finite_difference_solver(nx=100, ny=100, max_iter=10000, tolerance=1e-7):
    x = np.linspace(0, 1, nx)
    y = np.linspace(0, 1, ny)

    dx = x[1] - x[0]
    dy = y[1] - y[0]

    X, Y = np.meshgrid(x, y)

    Q = heat_source_numpy(X, Y)

    T = np.ones((ny, nx)) * T_boundary

    for iteration in range(max_iter):
        T_old = T.copy()

        T[1:-1, 1:-1] = (
            (T[1:-1, 2:] + T[1:-1, :-2]) * dy**2
            + (T[2:, 1:-1] + T[:-2, 1:-1]) * dx**2
            + (Q[1:-1, 1:-1] / k) * dx**2 * dy**2
        ) / (2 * (dx**2 + dy**2))

        T[0, :] = T_boundary
        T[-1, :] = T_boundary
        T[:, 0] = T_boundary
        T[:, -1] = T_boundary

        diff = np.max(np.abs(T - T_old))

        if diff < tolerance:
            print(f"FDM converged at iteration {iteration}")
            break

    return X, Y, T


model = Heat2DPINN().to(device)

optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)

epochs = 20000
n_collocation = 3000

loss_history = []

for epoch in range(epochs):
    x_pde = torch.rand((n_collocation, 1), device=device)
    y_pde = torch.rand((n_collocation, 1), device=device)

    loss = pde_loss(model, x_pde, y_pde)

    optimizer.zero_grad()
    loss.backward()
    optimizer.step()

    loss_history.append(loss.item())

    if epoch % 1000 == 0:
        bc_err = boundary_error(model)

        print(
            f"Epoch {epoch:05d} | "
            f"PDE Loss: {loss.item():.8e} | "
            f"Boundary Error: {bc_err:.3e}"
        )


X_fdm, Y_fdm, T_fdm = finite_difference_solver(nx=100, ny=100)

x_flat = torch.tensor(X_fdm.reshape(-1, 1), dtype=torch.float32, device=device)
y_flat = torch.tensor(Y_fdm.reshape(-1, 1), dtype=torch.float32, device=device)

with torch.no_grad():
    T_pinn_flat = model(x_flat, y_flat).cpu().numpy()

T_pinn = T_pinn_flat.reshape(T_fdm.shape)

error = T_pinn - T_fdm

mae = np.mean(np.abs(error))
rmse = np.sqrt(np.mean(error ** 2))
max_error = np.max(np.abs(error))
relative_l2 = np.linalg.norm(error) / np.linalg.norm(T_fdm)

print("\nFinal PINN vs FDM Evaluation:")
print("MAE        :", mae)
print("RMSE       :", rmse)
print("Max Error  :", max_error)
print("Relative L2:", relative_l2)

print("\nMaximum Temperatures:")
print("PINN Tmax:", np.max(T_pinn))
print("FDM Tmax :", np.max(T_fdm))


plt.figure(figsize=(7, 5))
contour = plt.contourf(X_fdm, Y_fdm, T_pinn, levels=50)
plt.colorbar(contour, label="Temperature (K)")
plt.xlabel("x")
plt.ylabel("y")
plt.title("PINN Temperature Field: 2D Chip Hotspot")
plt.tight_layout()
plt.show()


plt.figure(figsize=(7, 5))
contour = plt.contourf(X_fdm, Y_fdm, T_fdm, levels=50)
plt.colorbar(contour, label="Temperature (K)")
plt.xlabel("x")
plt.ylabel("y")
plt.title("FDM Temperature Field: 2D Chip Hotspot")
plt.tight_layout()
plt.show()


plt.figure(figsize=(7, 5))
contour = plt.contourf(X_fdm, Y_fdm, error, levels=50)
plt.colorbar(contour, label="PINN - FDM Error (K)")
plt.xlabel("x")
plt.ylabel("y")
plt.title("Error Heatmap: PINN vs FDM")
plt.tight_layout()
plt.show()


Q_plot = heat_source_numpy(X_fdm, Y_fdm)

plt.figure(figsize=(7, 5))
contour = plt.contourf(X_fdm, Y_fdm, Q_plot, levels=50)
plt.colorbar(contour, label="Heat Source Q(x,y)")
plt.xlabel("x")
plt.ylabel("y")
plt.title("Gaussian Heat Source / Hotspot")
plt.tight_layout()
plt.show()


plt.figure(figsize=(7, 5))
plt.semilogy(loss_history, linewidth=2)
plt.xlabel("Epoch")
plt.ylabel("PDE Loss")
plt.title("PINN Training Loss: 2D Steady-State Heat Equation")
plt.grid(True)
plt.tight_layout()
plt.show()


mid_index = T_fdm.shape[0] // 2

plt.figure(figsize=(7, 5))
plt.plot(
    X_fdm[mid_index, :],
    T_fdm[mid_index, :],
    label="FDM Centerline",
    linewidth=2
)

plt.plot(
    X_fdm[mid_index, :],
    T_pinn[mid_index, :],
    "--",
    label="PINN Centerline",
    linewidth=2
)

plt.xlabel("x at y=0.5")
plt.ylabel("Temperature (K)")
plt.title("Centerline Temperature Comparison")
plt.legend()
plt.grid(True)
plt.tight_layout()
plt.show()
