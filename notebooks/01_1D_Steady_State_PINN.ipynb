import torch
import torch.nn as nn
import numpy as np
import matplotlib.pyplot as plt

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print("Using device:", device)

T_left = 400.0
T_right = 300.0


class PINN(nn.Module):
    def __init__(self, hidden_dim=64, num_hidden_layers=4):
        super().__init__()

        layers = [nn.Linear(1, hidden_dim), nn.Tanh()]

        for _ in range(num_hidden_layers):
            layers += [nn.Linear(hidden_dim, hidden_dim), nn.Tanh()]

        layers.append(nn.Linear(hidden_dim, 1))
        self.network = nn.Sequential(*layers)

    def forward(self, x):
        raw = self.network(x)

        boundary_solution = T_left * (1 - x) + T_right * x
        correction = x * (1 - x) * raw

        return boundary_solution + correction


def pde_loss(model, x):
    x.requires_grad_(True)

    T = model(x)

    T_x = torch.autograd.grad(
        T, x,
        grad_outputs=torch.ones_like(T),
        create_graph=True
    )[0]

    T_xx = torch.autograd.grad(
        T_x, x,
        grad_outputs=torch.ones_like(T_x),
        create_graph=True
    )[0]

    return torch.mean(T_xx ** 2)


def analytical_solution(x):
    return 400 - 100 * x


model = PINN().to(device)
optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)

epochs = 10000
n_collocation = 100

loss_history = []

for epoch in range(epochs):
    x_pde = torch.rand((n_collocation, 1), device=device)

    loss = pde_loss(model, x_pde)

    optimizer.zero_grad()
    loss.backward()
    optimizer.step()

    loss_history.append(loss.item())

    if epoch % 1000 == 0:
        print(f"Epoch {epoch:05d} | PDE Loss: {loss.item():.8e}")


x_test = torch.linspace(0, 1, 200).view(-1, 1).to(device)

with torch.no_grad():
    T_pinn = model(x_test).cpu().numpy()

x_np = x_test.cpu().numpy()
T_exact = analytical_solution(x_np)

error = T_pinn - T_exact

print("MAE :", np.mean(np.abs(error)))
print("RMSE:", np.sqrt(np.mean(error ** 2)))


plt.figure(figsize=(7, 5))
plt.plot(x_np, T_exact, label="Analytical", linewidth=2)
plt.plot(x_np, T_pinn, "--", label="PINN", linewidth=2)
plt.xlabel("x")
plt.ylabel("Temperature (K)")
plt.title("1D Steady-State Heat Conduction")
plt.legend()
plt.grid(True)
plt.show()


plt.figure(figsize=(7, 5))
plt.plot(x_np, error)
plt.xlabel("x")
plt.ylabel("Error (K)")
plt.title("Prediction Error")
plt.grid(True)
plt.show()


plt.figure(figsize=(7, 5))
plt.semilogy(loss_history)
plt.xlabel("Epoch")
plt.ylabel("PDE Loss")
plt.title("Training Loss")
plt.grid(True)
plt.show()
